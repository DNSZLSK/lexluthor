# Dépendances
node_modules/

# Build
dist/

# Binaires WASM : régénérés par le postinstall (scripts/copy-wasm.mjs) depuis
# node_modules, donc inutile de les versionner. `npm install` les recopie.
packages/core/wasm/
apps/web/public/wasm/
apps/vscode/media/wasm/

# Bundle webview (régénéré par esbuild)
apps/vscode/media/webview/

# Artefacts d'extension VS Code
*.vsix
apps/vscode/tools/*.cjs

# Logs / divers
*.log
.devserver.log
.DS_Store
Thumbs.db
